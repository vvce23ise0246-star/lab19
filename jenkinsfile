pipeline {
    agent any

    stages {
        stage('Clean Workspace') {
            steps {
                deleteDir() // optional but safe
            }
        }

        stage('Checkout') {
            steps {
                git 'https://github.com/vvce23ise0246-star/lab19.git'
            }
        }

        stage('Build Java') {
            steps {
                bat 'javac *.java'  // compile all Java files
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t my-java-app .' // build Docker image
            }
        }

        stage('Run Container') {
            steps {
                bat 'docker run my-java-app'        // run the container
            }
        }
    }
}